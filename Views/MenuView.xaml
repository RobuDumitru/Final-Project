<UserControl x:Class="LostInAForgottenCity.Views.MenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.Resources>
            <Style x:Key="ConsoleButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="#7aaa60"/>
                <Setter Property="FontFamily" Value="Courier New"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Margin" Value="0,5,0,5"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent">
                                <TextBlock x:Name="ButtonText"
                                           Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontFamily="{TemplateBinding FontFamily}"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonText" Property="Foreground" Value="#c8ff96"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Image Source="/Assets/menu_background.png" Stretch="UniformToFill"/>
        <Rectangle Fill="#80000000"/>

        <TextBlock Text="Lost in a Forgotten City"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,60,0,0"
                   FontSize="48"
                   FontWeight="Bold"
                   Foreground="#e8d5b0"
                   Opacity="0.9"/>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,120,0,0"
                    Width="300">
            <Button Content="  NEW GAME" Style="{StaticResource ConsoleButton}"
                    MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave"
                    Click="NewGame_Click"/>
            <Button Content="  CONTINUE" Style="{StaticResource ConsoleButton}"
                    MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave"/>
            <Button Content="  TUTORIAL" Style="{StaticResource ConsoleButton}"
                    MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave"
                    Click="Tutorial_Click"/>
            <Button Content="  SETTINGS" Style="{StaticResource ConsoleButton}"
                    MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave"/>
            <Button Content="  EXIT" Style="{StaticResource ConsoleButton}"
                    MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave"
                    Click="Exit_Click"/>
        </StackPanel>
    </Grid>
</UserControl>