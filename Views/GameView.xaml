<UserControl x:Class="LostInAForgottenCity.Views.GameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LostInAForgottenCity.Controls">
      <Grid Background="#0a0a0f">
            <Grid.RowDefinitions>
                  <RowDefinition Height="100"/>
                  <!-- top bar -->
                  <RowDefinition Height="*"/>
                  <!-- main area -->
                  <RowDefinition Height="80"/>
                  <!-- bottom bar -->
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="250"/>
                  <!-- map -->
                  <ColumnDefinition Width="*"/>
                  <!-- console -->
            </Grid.ColumnDefinitions>

            <!-- Placeholders go here, inside the Grid but after definitions -->

            <!-- Top bar spans both columns -->
            <Grid Grid.Row="0"
                  Grid.Column="0"
                  Grid.ColumnSpan="2"
                  Background="#1a1a2a">
                  <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <!-- left -->
                        <ColumnDefinition Width="300"/>
                        <!-- center -->
                        <ColumnDefinition Width="*"/>
                        <!-- right -->
                  </Grid.ColumnDefinitions>

                  <!-- LEFT: Sanity + Circles + Danger -->
                  <Grid Grid.Column="0"
                        Margin="10,5,5,5">
                        <Grid.RowDefinitions>
                              <RowDefinition Height="Auto"/>
                              <!-- Sanity -->
                              <RowDefinition Height="Auto"/>
                              <!-- Subconscious -->
                              <RowDefinition Height="Auto"/>
                              <!-- Danger -->
                        </Grid.RowDefinitions>

                        <!-- Row 1: Sanity bar -->
                        <controls:SanityBar Grid.Row="0"
                                            Value="100"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"/>

                        <!-- Row 2: Circles + Danger -->
                        <controls:SubconsciousBar Grid.Row="1"
                                                  Value="0"
                                                  MaxSlots="5"
                                                  VerticalAlignment="Center"/>
                        <controls:DangerIndicator Grid.Row="2"
                                                  Level="Insignificant"
                                                  StatusEffect=""
                                                  VerticalAlignment="Center"/>
                  </Grid>

                  <!-- CENTER: Soul + Resistance + Clock + Weather -->
                  <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                              <RowDefinition Height="*"/>
                              <RowDefinition Height="*"/>
                              <RowDefinition Height="*"/>
                              <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Row 1: Soul bar -->
                        <controls:SoulBar Grid.Row="0" Value="50" MaxValue="50"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>

                        <!-- Row 2: Resistance bar -->
                        <controls:ResistanceBar Grid.Row="1" Value="20" MaxValue="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>

                        <!-- Row 3: Clock -->
                        <TextBlock Grid.Row="2"
                                   x:Name="ClockText"
                                   Text="Day 1 — 15:00"
                                   FontFamily="Courier New"
                                   FontSize="13"
                                   Foreground="#c8c8b0"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <!-- Row 4: Weather -->
                        <TextBlock Grid.Row="3"
                                   x:Name="WeatherText"
                                   Text="🌫️ Day — Foggy"
                                   FontFamily="Courier New"
                                   FontSize="11"
                                   Foreground="#8a8a7a"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                  </Grid>

                  <!-- RIGHT: HP + Stamina + Sleep -->
                  <Grid Grid.Column="2"
                        Margin="5,5,15,5"
                              MinWidth="380">
                        <Grid.RowDefinitions>
                              <RowDefinition Height="Auto"/>
                              <!-- HP -->
                              <RowDefinition Height="Auto"/>
                              <!-- Stamina + Sleep -->
                        </Grid.RowDefinitions>

                        <controls:HpBar Grid.Row="0"
                                        Value="10"
                                        MaxSegments="20"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"/>

                        <controls:StaminaSleepBar Grid.Row="1"
                                                  Value="10"
                                                  MaxSegments="10"
                                                  SleepValue="100"
                                                  IsSleepVisible="True"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"/>

                  </Grid>
            </Grid>

            <!-- Map -->
            <Rectangle Fill="#0d1a0d"
                       Grid.Row="1"
                       Grid.Column="0"/>

            <!-- Console -->
            <Rectangle Fill="#1a0d0d"
                       Grid.Row="1"
                       Grid.Column="1"/>

            <!-- Bottom bar spans both columns -->
            <Rectangle Fill="#1a1a2a"
                       Grid.Row="2"
                       Grid.Column="0"
                       Grid.ColumnSpan="2"/>

      </Grid>
</UserControl>