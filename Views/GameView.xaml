<UserControl x:Class="LostInAForgottenCity.Views.GameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LostInAForgottenCity.Controls">
    <Grid Background="#0a0a0f">
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ TOP BAR ═══ -->
        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
              Background="#1a1a2a">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- MIND BOX -->
            <Border Grid.Column="0" BorderBrush="#9a7a9a"
                    BorderThickness="1" Margin="8,4,4,4">
                <Grid>
                    <TextBlock Text="MIND" FontFamily="Courier New"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="#9a7a9a"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,2,0,0"/>
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <controls:SanityBar Value="50"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,4"/>
                        <WrapPanel>
                            <controls:SubconsciousBar Value="5"
                                                      MaxSlots="10"/>
                            <controls:DangerIndicator Level="Insignificant"
                                                      StatusEffect="None"
                                                      Margin="8,0,0,0"
                                                      VerticalAlignment="Center"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- SPIRIT BOX -->
            <Border Grid.Column="1" BorderBrush="#c8a8d0"
                    BorderThickness="1" Margin="4,4,4,4">
                <Grid>
                    <TextBlock Text="SPIRIT" FontFamily="Courier New"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="#c8a8d0"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,2,0,0"/>
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <controls:SoulBar Value="25" MaxValue="100"/>
                        <controls:ResistanceBar Value="10" MaxValue="30"
                                                Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- BODY BOX -->
            <Border Grid.Column="2" BorderBrush="#aa6060"
                    BorderThickness="1" Margin="4,4,8,4">
                <Grid>
                    <TextBlock Text="BODY" FontFamily="Courier New"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="#aa6060"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,2,0,0"/>
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <controls:HpBar Value="10" MaxSegments="20"/>
                        <controls:StaminaSleepBar Value="5"
                                                  MaxSegments="10"
                                                  SleepValue="50"
                                                  IsSleepVisible="True"
                                                  Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ MAP ═══ -->
        <Rectangle Fill="#0d1a0d" Grid.Row="1" Grid.Column="0"/>

        <!-- ═══ CONSOLE ═══ -->
        <Rectangle Fill="#1a0d0d" Grid.Row="1" Grid.Column="1"/>

        <!-- ═══ BOTTOM BAR ═══ -->
        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
              Background="#1a1a2a">
            <Grid.RowDefinitions>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Separator line -->
            <Rectangle Grid.Row="0" Fill="#3a3a4a"/>

            <!-- Bottom bar content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Navigation buttons -->
                <StackPanel Grid.Column="0" Orientation="Vertical"
                            VerticalAlignment="Center"
                            Margin="15,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ObjectivesBtn"
                                Content="  OBJECTIVES"
                                FontFamily="Courier New" FontSize="13"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#7aaa60" Cursor="Hand"
                                MouseEnter="MenuButton_MouseEnter"
                                MouseLeave="MenuButton_MouseLeave"/>
                        <Button x:Name="CollectionsBtn"
                                Content="  COLLECTIONS"
                                FontFamily="Courier New" FontSize="13"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#7aaa60" Cursor="Hand"
                                Margin="15,0,0,0"
                                MouseEnter="MenuButton_MouseEnter"
                                MouseLeave="MenuButton_MouseLeave"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="HistoryBtn"
                                Content="  HISTORY"
                                FontFamily="Courier New" FontSize="13"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#7aaa60" Cursor="Hand"
                                MouseEnter="MenuButton_MouseEnter"
                                MouseLeave="MenuButton_MouseLeave"/>
                        <Button x:Name="PauseBtn"
                                Content="  PAUSE"
                                FontFamily="Courier New" FontSize="13"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#7aaa60" Cursor="Hand"
                                Margin="15,0,0,0"
                                MouseEnter="MenuButton_MouseEnter"
                                MouseLeave="MenuButton_MouseLeave"/>
                    </StackPanel>
                </StackPanel>

                <!-- CENTER: Clock + Weather -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <Button x:Name="ClockBtn"
                            Content="Day 1 — 15:00"
                            FontFamily="Courier New" FontSize="15"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#c8c8b0" Cursor="Hand"
                            Click="ClockBtn_Click"
                            MouseEnter="MenuButton_MouseEnter"
                            MouseLeave="MenuButton_MouseLeave"/>
                    <Button x:Name="WeatherBtn"
                            Content="Day — Foggy"
                            FontFamily="Courier New" FontSize="12"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#8a8a7a" Cursor="Hand"
                            Click="WeatherBtn_Click"
                            MouseEnter="MenuButton_MouseEnter"
                            MouseLeave="MenuButton_MouseLeave"/>
                </StackPanel>

                <!-- RIGHT: Relic counter + Inventory -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,15,0">
                    <StackPanel VerticalAlignment="Center"
                                Margin="0,0,10,0">
                        <TextBlock Text="RELICS"
                                   FontFamily="Courier New" FontSize="11"
                                   Foreground="#c8a840"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="RelicCount" Text="0"
                                   FontFamily="Courier New" FontSize="16"
                                   Foreground="#c8a840"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    <controls:InventoryBar x:Name="Inventory"
                                           SlotCount="6"
                                           VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>