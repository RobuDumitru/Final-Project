<UserControl x:Class="LostInAForgottenCity.Views.GameView"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:controls="clr-namespace:LostInAForgottenCity.Controls">
    <Grid Background="#0a0a0f">
        <Grid.RowDefinitions>
            <RowDefinition Height="120"/>  <!-- top bar -->
            <RowDefinition Height="*"/>    <!-- main area -->
            <RowDefinition Height="80"/>   <!-- bottom bar -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/> <!-- map -->
            <ColumnDefinition Width="*"/>   <!-- console -->
        </Grid.ColumnDefinitions>

        <!-- ═══ TOP BAR ═══ -->
        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
              Background="#1a1a2a">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>    <!-- MIND -->
                <ColumnDefinition Width="1.4*"/> <!-- SPIRIT -->
                <ColumnDefinition Width="1*"/>    <!-- BODY -->
            </Grid.ColumnDefinitions>

            <!-- MIND BOX -->
            <Border Grid.Column="0" BorderBrush="#9a7a9a"
                    BorderThickness="1" Margin="8,4,4,4">
                <Grid>
                    <!-- MIND = box label only -->
                    <TextBlock Text="MIND" FontFamily="Courier New"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="#9a7a9a"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,2,0,0"/>

                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,0">
                        <controls:SanityBar Value="50"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,4"/>
                        <WrapPanel>
                            <controls:SubconsciousBar Value="5"
                                                      MaxSlots="10"
                                                      HorizontalAlignment="Center"/>
                            <controls:DangerIndicator Level="Insignificant"
                                                      StatusEffect="None"
                                                      Margin="8,0,0,0"
                                                      VerticalAlignment="Center"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- SPIRIT BOX -->
            <Border Grid.Column="1" BorderBrush="#c8a8d0"
                    BorderThickness="1" Margin="4,4,4,4">
                <Grid>
                    <!-- SPIRIT = box label only -->
                    <TextBlock Text="SPIRIT" FontFamily="Courier New"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="#c8a8d0"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,2,0,0"/>

                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <controls:SoulBar Value="25" MaxValue="100"/>
                        <controls:ResistanceBar Value="10" MaxValue="30"
                                                Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- BODY BOX -->
            <Border Grid.Column="2" BorderBrush="#aa6060"
                    BorderThickness="1" Margin="4,4,8,4">
                <Grid>
                    <!-- BODY = box label only -->
                    <TextBlock Text="BODY" FontFamily="Courier New"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="#aa6060"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Margin="0,2,0,0"/>

                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <controls:HpBar Value="10" MaxSegments="20"/>
                        <controls:StaminaSleepBar Value="5"
                                                  MaxSegments="10"
                                                  SleepValue="50"
                                                  IsSleepVisible="True"
                                                  Margin="0,6,0,0"/>                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ MAP ═══ -->
        <Rectangle Fill="#0d1a0d"
                   Grid.Row="1"
                   Grid.Column="0"/>

        <!-- ═══ CONSOLE ═══ -->
        <Rectangle Fill="#1a0d0d"
                   Grid.Row="1"
                   Grid.Column="1"/>

        <!-- ═══ BOTTOM BAR ═══ -->
        <Rectangle Fill="#1a1a2a"
                   Grid.Row="2"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"/>

    </Grid>
</UserControl>