<UserControl x:Class="LostInAForgottenCity.Controls.StaminaSleepBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="STAMINA"
                       FontFamily="Courier New" FontSize="13"
                       Foreground="#60aa60" VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <StackPanel Grid.Column="1" x:Name="StaminaPanel"
                        Orientation="Horizontal"/>

            <Rectangle Grid.Column="2" Width="1"
                       Fill="#3a3a4a" Margin="6,0"/>

            <StackPanel Grid.Column="3" x:Name="SleepPanel"
                        Orientation="Horizontal"/>

            <TextBlock Grid.Column="4" Text="SLEEP"
                       FontFamily="Courier New" FontSize="13"
                       Foreground="#6060aa" VerticalAlignment="Center"
                       Margin="8,0,0,0"/>
        </Grid>
        <Rectangle Height="1" Fill="#3a3a4a" Margin="0,2,0,0"/>
    </StackPanel>
</UserControl>