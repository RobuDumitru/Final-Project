<UserControl x:Class="LostInAForgottenCity.Controls.SubconsciousBar"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel HorizontalAlignment="Left">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="SUBCONSCIOUS" FontFamily="Courier New"
                       FontSize="11" Foreground="#9a7a9a"
                       VerticalAlignment="Center"
                       Grid.Column="0"/>
            <TextBlock Grid.Column="1"/>
            <TextBlock x:Name="Label" Text="0/0"
                       FontFamily="Courier New" FontSize="10"
                       Foreground="#9a7a9a"
                       VerticalAlignment="Center"
                       Grid.Column="2"/>
        </Grid>

        <StackPanel x:Name="SlotsPanel" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,4,0,0"/>

        <Rectangle Height="1" Fill="#9a7a9a" Margin="0,4,0,0"/>
    </StackPanel>
</UserControl>