<UserControl x:Class="LostInAForgottenCity.Controls.ResistanceBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel HorizontalAlignment="Center">
        <TextBlock Text="RESISTANCE" FontFamily="Courier New"
                   FontSize="13" Foreground="#60c8a0"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,2"/>
        <StackPanel x:Name="ResistancePanel" Orientation="Horizontal"
                    HorizontalAlignment="Center"/>
        <Rectangle Height="1" Fill="#60c8a0" Margin="0,2,0,0"/>
    </StackPanel>
</UserControl>