<UserControl x:Class="LostInAForgottenCity.Controls.ResistanceBar"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel HorizontalAlignment="Center">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="RESISTANCE" FontFamily="Courier New"
                       FontSize="11" Foreground="#60c8a0"
                       VerticalAlignment="Center"
                       Grid.Column="0"/>
            <TextBlock Grid.Column="1"/>
            <TextBlock x:Name="Label" Text="50/50"
                       FontFamily="Courier New" FontSize="10"
                       Foreground="#60c8a0"
                       VerticalAlignment="Center"
                       Grid.Column="2"/>
        </Grid>

        <StackPanel x:Name="ResistancePanel" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,4,0,0"/>

        <Rectangle Height="1" Fill="#60c8a0" Margin="0,4,0,0"/>
    </StackPanel>
</UserControl>