<UserControl x:Class="LostInAForgottenCity.Controls.SanityBar"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel HorizontalAlignment="Center" MinWidth="350">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="SANITY" FontFamily="Courier New"
                       FontSize="11" Foreground="#7aaa60"
                       VerticalAlignment="Center"
                       Grid.Column="0"/>
            <TextBlock Grid.Column="1"/>
            <TextBlock x:Name="PercentText" Text="100%"
                       FontFamily="Courier New" FontSize="10"
                       Foreground="#7aaa60"
                       VerticalAlignment="Center"
                       Grid.Column="2"/>
        </Grid>

        <ProgressBar x:Name="Bar" Value="100" Maximum="100"
                     Height="12" HorizontalAlignment="Stretch"
                     Background="#1a2a1a" Margin="0,4,0,0"/>

        <Rectangle Height="1" Fill="#7aaa60" Margin="0,4,0,0"/>
    </StackPanel>
</UserControl>