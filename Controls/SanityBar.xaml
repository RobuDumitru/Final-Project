<UserControl x:Class="LostInAForgottenCity.Controls.SanityBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <TextBlock Text="SANITY" FontFamily="Courier New"
                   FontSize="11" Foreground="#7aaa60"
                   VerticalAlignment="Top"/>
        <ProgressBar x:Name="Bar" Value="100" Maximum="100"
                     Height="12" Margin="0,16,0,0"
                     HorizontalAlignment="Stretch"
                     Background="#1a2a1a"/>
        <TextBlock x:Name="PercentText" Text="100%"
                   FontFamily="Courier New" FontSize="11"
                   Foreground="#7aaa60"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"/>
    </Grid>
</UserControl>