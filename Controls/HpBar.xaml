<UserControl x:Class="LostInAForgottenCity.Controls.HpBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel HorizontalAlignment="Right">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Border BorderBrush="#aa6060" BorderThickness="1"
                    Padding="4,2" HorizontalAlignment="Right">
                <StackPanel x:Name="SegmentsPanel" Orientation="Horizontal"/>
            </Border>
            <TextBlock Text="HP" FontFamily="Courier New"
                       FontSize="13" Foreground="#aa6060"
                       VerticalAlignment="Center" Margin="6,0,0,0"/>
        </StackPanel>
        <Rectangle Height="1" Fill="#aa6060" Margin="0,2,0,0"/>
    </StackPanel>
</UserControl>