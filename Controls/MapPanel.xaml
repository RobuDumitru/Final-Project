<UserControl x:Class="LostInAForgottenCity.Controls.MapPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#0a0f0a">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- section title -->
            <RowDefinition Height="*"/>     <!-- map canvas -->
            <RowDefinition Height="Auto"/>  <!-- legend -->
        </Grid.RowDefinitions>

        <!-- Section title -->
        <TextBlock Grid.Row="0"
                   x:Name="SectionTitle"
                   Text="RURAL"
                   FontFamily="Courier New"
                   FontSize="11"
                   Foreground="#4a6a4a"
                   HorizontalAlignment="Center"
                   Margin="0,6,0,4"/>

        <!-- Map canvas -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#0a0f0a">
            <Canvas x:Name="MapCanvas" Margin="10,10,10,10"/>
        </ScrollViewer>

        <!-- Legend -->
        <Border Grid.Row="2"
                BorderBrush="#2a3a2a"
                BorderThickness="0,1,0,0"
                Padding="6,4">
            <StackPanel>
                <TextBlock Text="LEGEND"
                           FontFamily="Courier New"
                           FontSize="9"
                           Foreground="#4a6a4a"
                           Margin="0,0,0,3"/>
                <!-- State icons -->
                <WrapPanel>
                    <TextBlock Text="□ Unknown  "
                               FontFamily="Courier New"
                               FontSize="9"
                               Foreground="#3a4a3a"/>
                    <TextBlock Text="◈ Found  "
                               FontFamily="Courier New"
                               FontSize="9"
                               Foreground="#6a8a6a"/>
                    <TextBlock Text="◉ Visited  "
                               FontFamily="Courier New"
                               FontSize="9"
                               Foreground="#7aaa60"/>
                    <TextBlock Text="■ Explored  "
                               FontFamily="Courier New"
                               FontSize="9"
                               Foreground="#c8c860"/>
                    <TextBlock Text="◆ Looted"
                               FontFamily="Courier New"
                               FontSize="9"
                               Foreground="#c8a840"/>
                </WrapPanel>
                <!-- Special icons -->
                <WrapPanel Margin="0,2,0,0">
                    <TextBlock Text="● Here  "
                               FontFamily="Courier New"
                               FontSize="9"
                               Foreground="#7aaa60"/>
                    <TextBlock Text="★ Main  "
                               FontFamily="Courier New"
                               FontSize="9"
                               Foreground="#ffcc00"/>
                    <TextBlock Text="◈ Side  "
                               FontFamily="Courier New"
                               FontSize="9"
                               Foreground="#60c8c8"/>
                    <TextBlock Text="✦ Special  "
                               FontFamily="Courier New"
                               FontSize="9"
                               Foreground="#c860c8"/>
                    <TextBlock Text="⌂ Safe  "
                               FontFamily="Courier New"
                               FontSize="9"
                               Foreground="#60a8d0"/>
                    <TextBlock Text="▲ Danger  "
                               FontFamily="Courier New"
                               FontSize="9"
                               Foreground="#c87840"/>
                    <TextBlock Text="✕ Locked"
                               FontFamily="Courier New"
                               FontSize="9"
                               Foreground="#888888"/>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>